# Database
DATABASE_URL=postgresql+asyncpg://scrollar:scrollar@db:5432/scrollar
DATABASE_URL_SYNC=postgresql+psycopg2://scrollar:scrollar@db:5432/scrollar

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Auth — generate a real secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OpenRouter
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=ScrollAr

# arXiv ingestion
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CV,stat.ML,cs.CL,cs.RO
ARXIV_FETCH_LIMIT=100
ARXIV_INGEST_INTERVAL_HOURS=6

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin — your email to access /api/admin/* endpoints
ADMIN_EMAIL=you@example.com

# App
DEBUG=false
APP_VERSION=0.1.0
